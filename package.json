{
  "name": "authorkit-website",
  "version": "1.0.0",
  "description": "Marketing website for AuthorKit WordPress plugins",
  "scripts": {
    "dev": "python3 -m http.server 8000",
    "serve": "python3 -m http.server 8000",
    "build:css": "tailwindcss -i ./css/input.css -o ./css/styles.css --minify",
    "build:css:watch": "tailwindcss -i ./css/input.css -o ./css/styles.css --watch",
    "build:css:debug": "tailwindcss -i ./css/input.css -o ./css/styles.css",
    "watch:css": "tailwindcss -i ./css/input.css -o ./css/styles.css --watch",
    "analyze:css": "tailwindcss -i ./css/input.css -o ./css/styles.css --minify && ls -lh ./css/styles.css",
    "build:js": "terser js/main.js -o js/main.min.js -c -m && terser js/bookshelf.js -o js/bookshelf.min.js -c -m && terser js/bookshelf-browse.js -o js/bookshelf-browse.min.js -c -m",
    "build": "npm run build:css && npm run build:js",
    "build:prod": "NODE_ENV=production npm run build:css && npm run build:js",
    "clean": "rm -f css/styles.css js/*.min.js"
  },
  "keywords": ["authorkit", "wordpress", "plugins", "authors"],
  "author": "AuthorKit",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.10.0",
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "@lhci/cli": "^0.15.1",
    "axe-core": "^4.10.0",
    "cssnano": "^7.1.3",
    "lighthouse": "^13.0.3",
    "postcss": "^8.4.47",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.4.1",
    "terser": "^5.46.1"
  }
}
