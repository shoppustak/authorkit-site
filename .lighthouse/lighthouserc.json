{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "url": [
        "http://localhost:8000/",
        "http://localhost:8000/features.html",
        "http://localhost:8000/pricing.html",
        "http://localhost:8000/docs.html"
      ],
      "settings": {
        "formFactor": "mobile",
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638,
          "cpuSlowdownMultiplier": 4
        },
        "screenEmulation": {
          "mobile": true,
          "width": 360,
          "height": 640,
          "deviceScaleFactor": 2
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", {"minScore": 0.95}],
        "categories:accessibility": ["error", {"minScore": 1.0}],
        "categories:best-practices": ["error", {"minScore": 0.95}],
        "categories:seo": ["error", {"minScore": 0.95}],
        "first-contentful-paint": ["warn", {"maxNumericValue": 1800}],
        "largest-contentful-paint": ["error", {"maxNumericValue": 2500}],
        "total-blocking-time": ["error", {"maxNumericValue": 200}],
        "cumulative-layout-shift": ["error", {"maxNumericValue": 0.1}],
        "speed-index": ["warn", {"maxNumericValue": 3400}],
        "interactive": ["error", {"maxNumericValue": 3000}],
        "resource-summary:script:size": ["error", {"maxNumericValue": 51200}],
        "resource-summary:stylesheet:size": ["error", {"maxNumericValue": 15360}],
        "resource-summary:document:size": ["warn", {"maxNumericValue": 15360}],
        "resource-summary:font:size": ["warn", {"maxNumericValue": 102400}],
        "resource-summary:image:size": ["warn", {"maxNumericValue": 512000}],
        "resource-summary:total:size": ["error", {"maxNumericValue": 716800}]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouse/optimized"
    }
  }
}
